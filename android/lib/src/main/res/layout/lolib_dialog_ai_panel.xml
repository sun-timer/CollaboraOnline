<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Assistant"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/ai_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <EditText
        android:id="@+id/ai_endpoint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:backgroundTint="#D1D5DB"
        android:hint="Endpoint (OpenAI-compatible)"
        android:inputType="textUri" />

    <EditText
        android:id="@+id/ai_model"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#D1D5DB"
        android:hint="Model"
        android:inputType="text" />

    <EditText
        android:id="@+id/ai_api_key"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="#D1D5DB"
        android:hint="API Key"
        android:inputType="textPassword" />

    <EditText
        android:id="@+id/ai_prompt"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="#D1D5DB"
        android:gravity="top|start"
        android:hint="Prompt"
        android:inputType="textMultiLine" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/ai_run"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="#2563EB"
            android:textColor="#FFFFFF"
            android:text="Run" />

        <Button
            android:id="@+id/ai_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#4B5563"
            android:textColor="#FFFFFF"
            android:text="Cancel" />

        <Button
            android:id="@+id/ai_accept"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#15803D"
            android:textColor="#FFFFFF"
            android:text="Accept" />
    </LinearLayout>

    <TextView
        android:id="@+id/ai_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="State: ready - Ready"
        android:textColor="#2E7D32"
        android:textAppearance="?android:attr/textAppearanceSmall" />

    <TextView
        android:id="@+id/ai_output"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="8dp"
        android:background="#F3F4F6"
        android:gravity="top|start"
        android:padding="8dp"
        android:textColor="#111827"
        android:textIsSelectable="true" />

</LinearLayout>
