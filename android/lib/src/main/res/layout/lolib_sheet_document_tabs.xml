<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F6F6F7"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="标签"
            android:textColor="#15171A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/tabs_sheet_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#E7E7E7"
            android:contentDescription="关闭"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="#E4E4E6"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/tabs_tab_opened"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:gravity="center"
            android:text="已打开"
            android:textColor="#202124"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tabs_tab_closed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="#E4E4E6"
            android:gravity="center"
            android:text="最近关闭"
            android:textColor="#80868B"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_marginTop="10dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/tabs_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <TextView
        android:id="@+id/tabs_open_document"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="12dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:text="打开文档"
        android:textColor="#202124"
        android:textSize="17sp"
        android:textStyle="bold" />
</LinearLayout>
