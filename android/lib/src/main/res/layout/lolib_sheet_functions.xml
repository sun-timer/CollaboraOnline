<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F6F6F7"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:text="功能"
            android:textColor="#15171A"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/function_sheet_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="#E7E7E7"
            android:contentDescription="关闭"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="14dp"
        android:background="#E4E4E6"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/function_tab_file"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#F4F5F7"
            android:gravity="center"
            android:text="文件操作"
            android:textColor="#202124"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/function_tab_review"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="#E4E4E6"
            android:gravity="center"
            android:text="审阅"
            android:textColor="#80868B"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/function_file_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/function_action_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:text="保存"
            android:textColor="#202124"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E3E3E3" />

        <TextView
            android:id="@+id/function_action_download"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:text="下载"
            android:textColor="#202124"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E3E3E3" />

        <TextView
            android:id="@+id/function_action_print"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:text="打印"
            android:textColor="#202124"
            android:textSize="18sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/function_review_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/function_action_word_count"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:text="字数统计"
            android:textColor="#202124"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E3E3E3" />

        <TextView
            android:id="@+id/function_action_find_replace"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:text="查找替换"
            android:textColor="#202124"
            android:textSize="18sp" />
    </LinearLayout>

</LinearLayout>
