<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/selection_menu_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/lolib_bg_toolbar_quick_panel"
    android:elevation="16dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="8dp"
    android:paddingTop="10dp"
    android:paddingEnd="8dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:id="@+id/selection_menu_select_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="64dp"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="全选"
            android:src="@drawable/lolib_ic_selection_select_all" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="全选"
            android:textColor="#202124"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/selection_menu_copy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="64dp"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="复制"
            android:src="@drawable/lolib_ic_selection_copy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="复制"
            android:textColor="#202124"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/selection_menu_paste"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="64dp"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="粘贴"
            android:src="@drawable/lolib_ic_selection_paste" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="粘贴"
            android:textColor="#202124"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/selection_menu_cut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:minWidth="64dp"
        android:orientation="vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:contentDescription="剪切"
            android:src="@drawable/lolib_ic_selection_cut" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="剪切"
            android:textColor="#202124"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
