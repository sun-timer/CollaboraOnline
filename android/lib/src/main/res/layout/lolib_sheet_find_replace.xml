<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F6F6F7"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/find_sheet_settings"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="设置"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_find_settings" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="查找替换"
            android:textColor="#15171A"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/find_sheet_close"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="#E7E7E7"
            android:contentDescription="关闭"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="#E4E4E6"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/find_tab_find"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:gravity="center"
            android:text="查找"
            android:textColor="#202124"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/find_tab_replace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="#E4E4E6"
            android:gravity="center"
            android:text="替换"
            android:textColor="#80868B"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/find_panel_find"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/find_query_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:hint="请输入查找内容"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#202124"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/find_btn_prev"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="上一个"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lolib_ic_find_prev" />

            <ImageButton
                android:id="@+id/find_btn_next"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="下一个"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lolib_ic_find_next" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/find_panel_replace"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        android:visibility="gone">

        <EditText
            android:id="@+id/find_replace_query_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:hint="请输入查找内容"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#202124"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/find_replace_with_input"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:hint="请输入替换内容"
            android:inputType="text"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:textColor="#202124"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/find_replace_btn_prev"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="上一个"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lolib_ic_find_prev" />

            <ImageButton
                android:id="@+id/find_replace_btn_next"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="下一个"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lolib_ic_find_next" />

            <ImageButton
                android:id="@+id/find_replace_btn_all"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="全部替换"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lolib_ic_find_replace_all" />

            <ImageButton
                android:id="@+id/find_replace_btn_one"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:adjustViewBounds="true"
                android:background="@null"
                android:contentDescription="替换"
                android:padding="0dp"
                android:scaleType="fitCenter"
                android:src="@drawable/lolib_ic_find_replace" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
