<?xml version="1.0" encoding="utf-8"?>
<!-- Selection popup: compact 5+5+2 layout per design spec.
     Row 1: copy/cut/paste/select_all/translate
     Row 2: outline/continue_write/article_generate/expand/polish
     Row 3: condense/rewrite (left-aligned) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/selection_popup_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/lolib_bg_selection_popup"
    android:elevation="40dp"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingTop="4dp"
    android:paddingEnd="4dp"
    android:paddingBottom="4dp">

    <!-- Row 1: 基础操作 + 翻译 -->
    <LinearLayout
        android:id="@+id/selection_basic_row"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/selection_op_copy"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_selection_copy" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="复制" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_cut"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_selection_cut" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="剪切" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_paste"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_selection_paste" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="粘贴" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_select_all"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_selection_select_all" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="全选" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_translate"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_translate" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="翻译" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider 1 -->
    <View
        android:id="@+id/selection_divider_1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D8D8D8" />

    <!-- Row 2: AI 操作 (1) -->
    <LinearLayout
        android:id="@+id/selection_ai_row_1"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/selection_op_outline"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_outline" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="总结大纲" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_continue_write"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_continue_write" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="文案续写" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_article_generate"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_article_generate" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="文案生成" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_expand"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_expand" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="文案扩写" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_polish"
            style="@style/SelectionPopupButton">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_polish" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="文案润色" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider 2 -->
    <View
        android:id="@+id/selection_divider_2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D8D8D8" />

    <!-- Row 3: AI 操作 (2), left-aligned -->
    <LinearLayout
        android:id="@+id/selection_ai_row_2"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/selection_op_condense"
            style="@style/SelectionPopupButtonCompact">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_condense" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="文案缩写" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/selection_op_rewrite"
            style="@style/SelectionPopupButtonCompact">

            <ImageView
                style="@style/SelectionPopupButtonIcon"
                android:src="@drawable/lolib_ic_ai_rewrite" />

            <TextView
                style="@style/SelectionPopupButtonText"
                android:text="文案重写" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
