<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/doc_top_toolbar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:elevation="8dp"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- Preview / Viewing mode -->
    <LinearLayout
        android:id="@+id/top_toolbar_preview"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <ImageButton
            android:id="@+id/top_btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="返回"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_back" />

        <TextView
            android:id="@+id/top_title_preview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingStart="4dp"
            android:paddingEnd="8dp"
            android:textColor="#202124"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/top_btn_search_preview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="搜索"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_search" />

        <ImageButton
            android:id="@+id/top_btn_share_preview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="分享"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_share" />

        <ImageButton
            android:id="@+id/top_btn_recent_preview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="最近打开"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_recent" />
    </LinearLayout>

    <!-- Edit mode -->
    <LinearLayout
        android:id="@+id/top_toolbar_edit"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/top_btn_done"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/lolib_bg_top_done_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minWidth="72dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="完成"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/top_btn_undo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="撤销"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_undo" />

        <ImageButton
            android:id="@+id/top_btn_redo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="恢复"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_redo" />

        <ImageButton
            android:id="@+id/top_btn_search_edit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="搜索"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_search" />

        <ImageButton
            android:id="@+id/top_btn_recent_edit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="最近打开"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_recent" />

        <ImageButton
            android:id="@+id/top_btn_close_edit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭编辑"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:src="@drawable/lolib_ic_top_close_edit" />
    </LinearLayout>
</LinearLayout>
