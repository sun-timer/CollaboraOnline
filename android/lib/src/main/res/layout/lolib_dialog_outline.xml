<?xml version="1.0" encoding="utf-8"?>
<!-- 生成大纲弹窗：670×756dp（完成态扩展到 972dp，高度由 Java setLayout 控制） -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/lolib_bg_dialog_outline"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <!-- ============== 标题行 ============== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="生成大纲"
            android:src="@drawable/lolib_ic_ai_outline" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="生成大纲"
            android:textColor="#1F1F1F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/outline_close_btn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </LinearLayout>

    <!-- ============== 类型选择卡（下拉） ============== -->
    <LinearLayout
        android:id="@+id/outline_type_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/lolib_bg_outline_edit"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:minHeight="64dp"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="大纲类型"
            android:textColor="#999999"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/outline_type_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="通用文档"
            android:textColor="#333333"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="选择类型"
            android:src="@drawable/lolib_ic_arrow_down" />
    </LinearLayout>

    <!-- ============== 补充说明输入卡（输入态） ============== -->
    <LinearLayout
        android:id="@+id/outline_desc_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/lolib_bg_outline_edit"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="16dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <EditText
            android:id="@+id/outline_desc_edit"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@null"
            android:gravity="top|start"
            android:hint="请输入补充说明，例如：围绕数字化转型展开，面向中层管理者..."
            android:inputType="textMultiLine|textCapSentences"
            android:textColor="#333333"
            android:textColorHint="#999999"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- ============== 结果区（完成态）：可滚动大纲文本 ============== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/outline_result_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/lolib_bg_outline_edit"
        android:fillViewport="true"
        android:visibility="gone">

        <TextView
            android:id="@+id/outline_result_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"
            android:text="正在生成大纲..."
            android:textColor="#333333"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp" />
    </androidx.core.widget.NestedScrollView>

    <!-- ============== 复制条（完成态，结果区下方）：整宽横条 = 复制图标 + 文字 ============== -->
    <LinearLayout
        android:id="@+id/outline_copy_row"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="复制"
            android:src="@drawable/lolib_ic_copy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="复制"
            android:textColor="#6A6A6A"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- ============== 生成按钮（输入态） ============== -->
    <Button
        android:id="@+id/outline_generate_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/lolib_bg_gradient_button_outline"
        android:text="生成"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- ============== 完成态按钮行 ============== -->
    <LinearLayout
        android:id="@+id/outline_done_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <Button
            android:id="@+id/outline_regenerate_btn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/lolib_bg_outline_secondary_button"
            android:text="重新生成"
            android:textColor="#333333"
            android:textSize="18sp" />

        <Button
            android:id="@+id/outline_apply_btn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/lolib_bg_gradient_button_outline"
            android:text="插入文档"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
