<?xml version="1.0" encoding="utf-8"?>
<!-- 格式批量处理弹窗：两阶段（INPUT 选项 / RESULT 结果） -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/lolib_bg_dialog_outline"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="20dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/format_batch_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="格式批量处理"
            android:textColor="#1F1F1F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/format_batch_close_btn"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_gravity="top|end"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="关闭"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel" />
    </FrameLayout>

    <!-- INPUT 阶段：6 个复选框 -->
    <ScrollView
        android:id="@+id/format_batch_options_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:fadeScrollbars="false"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/fb_option_en_to_zh"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="英文标点转中文"
                android:textColor="#333333"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/fb_option_zh_to_en"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="中文标点转英文"
                android:textColor="#333333"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/fb_option_ghost"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="幽灵字符转空格"
                android:textColor="#333333"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/fb_option_blank_lines"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="删除多余空行"
                android:textColor="#333333"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/fb_option_wavy"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="消除下滑波浪线"
                android:textColor="#333333"
                android:textSize="16sp" />

            <CheckBox
                android:id="@+id/fb_option_hyperlink"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:paddingStart="8dp"
                android:text="消除超链接识别"
                android:textColor="#333333"
                android:textSize="16sp" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/format_batch_execute_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/lolib_bg_gradient_button_outline"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="开始执行"
            android:src="@drawable/lolib_ic_btn_generate" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="开始执行"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- RESULT 阶段 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/format_batch_result_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_weight="1"
        android:background="@drawable/lolib_bg_outline_edit"
        android:fadeScrollbars="false"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay"
        android:visibility="gone">

        <TextView
            android:id="@+id/format_batch_result_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="16dp"
            android:paddingEnd="20dp"
            android:paddingBottom="16dp"
            android:textColor="#333333"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp" />
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/format_batch_copy_row"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:contentDescription="复制"
            android:src="@drawable/lolib_ic_copy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="复制"
            android:textColor="#6A6A6A"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/format_batch_done_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/format_batch_regenerate_btn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:background="@drawable/lolib_bg_outline_secondary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="重新生成"
                android:src="@drawable/lolib_ic_btn_regenerate" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="重新生成"
                android:textColor="#333333"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/format_batch_apply_btn"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:background="@drawable/lolib_bg_gradient_button_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="插入文档"
                android:src="@drawable/lolib_ic_btn_insert" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="插入文档"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
