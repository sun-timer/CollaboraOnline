<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Selection Popup Button Style: icon over label, no border (matches Figma SVG) -->
    <style name="SelectionPopupButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="SelectionPopupButtonIcon">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:contentDescription">图标</item>
    </style>

    <style name="SelectionPopupButtonText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
