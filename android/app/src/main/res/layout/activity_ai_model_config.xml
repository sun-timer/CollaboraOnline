<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#66000000"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="@dimen/ai_drawer_panel_width"
        android:layout_height="match_parent"
        android:background="#F3F3F3"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageButton
                android:id="@+id/modelConfigBackButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/action_back"
                android:padding="4dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back_arrow" />

            <TextView
                android:id="@+id/modelConfigTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="#111111"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D9DCE0" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingTop="14dp"
                android:paddingEnd="16dp"
                android:paddingBottom="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_ai_settings_card"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/modelConnectionIcon"
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:contentDescription="@string/ai_connection"
                            android:src="@drawable/ic_model_base"
                            android:tint="#FF6D00" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/ai_connection"
                            android:textColor="#FF6D00"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/ai_config_name"
                        android:textColor="#202124"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/modelConfigNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_ai_input_field"
                        android:hint="@string/ai_config_name_hint"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#202124"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/ai_provider"
                        android:textColor="#202124"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/modelProviderInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_ai_input_field"
                        android:hint="@string/ai_provider_hint"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#202124"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/ai_url"
                        android:textColor="#202124"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/modelUrlInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_ai_input_field"
                        android:hint="https://api.openai.com/v1/chat/completions"
                        android:inputType="textUri"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#202124"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/ai_api_key"
                        android:textColor="#202124"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/modelApiKeyInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_ai_input_field"
                        android:hint="sk-..."
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#202124"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/ai_model_name_label"
                        android:textColor="#202124"
                        android:textSize="16sp" />

                    <EditText
                        android:id="@+id/modelNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_ai_input_field"
                        android:hint="gpt-4o-mini"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="#202124"
                        android:textSize="17sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_ai_settings_card"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingTop="14dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:contentDescription="@string/ai_params"
                            android:src="@android:drawable/ic_menu_manage"
                            android:tint="#FF6D00" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:text="@string/ai_params"
                            android:textColor="#FF6D00"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <include layout="@layout/item_ai_slider_top_p" />
                    <include layout="@layout/item_ai_slider_temperature" />
                    <include layout="@layout/item_ai_slider_presence_penalty" />
                    <include layout="@layout/item_ai_slider_frequency_penalty" />
                    <include layout="@layout/item_ai_slider_max_tokens" />
                    <include layout="@layout/item_ai_slider_seed" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
                android:layout_height="90dp"
            android:background="#F3F3F3"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp">

            <Button
                android:id="@+id/modelConfigCancelButton"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:background="@drawable/bg_ai_btn_cancel"
                android:text="@string/action_cancel"
                android:textAllCaps="false"
                android:textColor="#202124"
                android:textSize="20sp" />

            <Button
                android:id="@+id/modelConfigSaveButton"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_weight="1"
                android:layout_marginStart="18dp"
                android:background="@drawable/bg_local_install_btn"
                android:text="@string/action_save"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="20sp" />
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/modelConfigScrim"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#00000000" />

</LinearLayout>
