<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F3F3F3"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="18dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/profileEntry"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/profileAvatar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:contentDescription="@string/ai_profile_name"
            android:src="@drawable/drawer_header" />

        <TextView
            android:id="@+id/profileNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/ai_profile_name"
            android:textColor="#202124"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/aiConfigCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="#E8E8E8"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/aiConfigIcon"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@string/ai_model_config_title"
                android:src="@drawable/ic_ai_config_tile" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_config_title"
                    android:textColor="#202124"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/ai_model_config_desc"
                    android:textColor="#5F6368"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/ai_model_select_hint"
            android:textColor="#5F6368"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/modelItemBase"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_model_item_selected"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_model_base"
                android:contentDescription="@string/ai_model_basic" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_basic"
                    android:textColor="#202124"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/modelBaseValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_unset"
                    android:textColor="#5F6368"
                    android:textSize="14sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/modelBaseArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="@string/open" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/modelItemThink"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_model_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_model_think"
                android:contentDescription="@string/ai_model_think" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_think"
                    android:textColor="#202124"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/modelThinkValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_unset"
                    android:textColor="#5F6368"
                    android:textSize="14sp" />
            </LinearLayout>
            <ImageView
                android:id="@+id/modelThinkArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="@string/open" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/modelItemImage"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_model_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_model_image"
                android:contentDescription="@string/ai_model_image" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_image"
                    android:textColor="#202124"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/modelImageValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_unset"
                    android:textColor="#5F6368"
                    android:textSize="14sp" />
            </LinearLayout>
            <ImageView
                android:id="@+id/modelImageArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="@string/open" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/modelItemVision"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_model_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_model_vision"
                android:contentDescription="@string/ai_model_vision" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_vision"
                    android:textColor="#202124"
                    android:textSize="15sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/modelVisionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_model_unset"
                    android:textColor="#5F6368"
                    android:textSize="14sp" />
            </LinearLayout>
            <ImageView
                android:id="@+id/modelVisionArrow"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_media_next"
                android:contentDescription="@string/open" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/ai_local_model"
            android:textColor="#5F6368"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_model_item"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/ai_local_inference"
                android:src="@drawable/ic_model_local" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/ai_local_inference"
                android:textColor="#202124"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/localInstallButton"
                android:layout_width="92dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_local_install_btn"
                android:text="@string/install"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
